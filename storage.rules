rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Profile photos ────────────────────────────────────────────────────────
    match /profiles/{uid}/{allPaths=**} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // Owner may delete their own profile photo (e.g. on account deletion).
      allow delete: if request.auth != null
        && request.auth.uid == uid;
    }

    // ── Post images ───────────────────────────────────────────────────────────
    match /posts/{authorUid}/{allPaths=**} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && request.auth.uid == authorUid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // Author may delete their own post images (post delete / account delete).
      allow delete: if request.auth != null
        && request.auth.uid == authorUid;
    }

    // ── Event banners ─────────────────────────────────────────────────────────
    match /events/{eventId}/{allPaths=**} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // Any authenticated user may delete event banners (matches open write above).
      allow delete: if request.auth != null;
    }

    // ── Club banners ──────────────────────────────────────────────────────────
    match /clubs/{clubId}/{allPaths=**} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // Any authenticated user may delete club banners (matches open write above).
      allow delete: if request.auth != null;
    }
  }
}
